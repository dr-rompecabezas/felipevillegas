{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm run build:css && python manage.py collectstatic --noinput"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "DJANGO_SETTINGS_MODULE=config.settings.production python manage.py migrate --noinput && gunicorn config.wsgi:application --bind 0.0.0.0:${PORT} --workers 3",
    "healthcheckPath": "/health/",
    "sleepApplication": false,
    "multiRegionConfig": {
      "us-east4-eqdc4a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
